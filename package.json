{
  "name": "controle-whatsapp-email",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --experimental-sqlite server/server.mjs",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "desktop": "electron electron/main.cjs",
    "installer:win": "npm run build && electron-builder --win nsis --x64",
    "deploy:vercel": "vercel --prod",
    "remote:update": "node scripts/remote-update.mjs",
    "check:prod-api": "node scripts/check-production-api.mjs"
  },
  "build": {
    "appId": "br.com.jusprevconecta.app",
    "productName": "JusPrevConecta",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "public/logo-cropped.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "JusPrevConecta-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JusPrevConecta"
    }
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
